---
import ProjectBase from "./ProjectBase.astro";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  year: string;
  image?: ImageMetadata;
  externalLink?: string;
}

const { title, year, image, externalLink } = Astro.props;
const pageTitle = `${title} - Romuald Tisserand`;

const projects = [
  { title: "Coach Pizza", slug: "coach-pizza" },
  { title: "Galleries", slug: "galleries" },
  { title: "THoT - Sia", slug: "thot" },
];

const currentPath = Astro.url.pathname;
const currentIndex = projects.findIndex((p) => currentPath.includes(p.slug));
const prevProject = currentIndex > 0 ? projects[currentIndex - 1] : null;
const nextProject =
  currentIndex < projects.length - 1 ? projects[currentIndex + 1] : null;

const breadcrumbs = [
  { name: "Accueil", url: "/" },
  { name: "Projets perso", url: "/perso" },
  { name: title, url: currentPath },
];

const navigation = {
  prev: prevProject
    ? { title: prevProject.title, url: `/perso/${prevProject.slug}` }
    : null,
  next: nextProject
    ? { title: nextProject.title, url: `/perso/${nextProject.slug}` }
    : null,
  prevLabel: "← Projet plus récent",
  nextLabel: "Projet plus ancien →",
};
---

<ProjectBase
  {title}
  {pageTitle}
  {year}
  {image}
  {externalLink}
  {breadcrumbs}
  {navigation}
  heroOverlayPosition="bottom"
>
  <slot />
</ProjectBase>
