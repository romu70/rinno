---
import ProjectBase from "./ProjectBase.astro";
import type { ImageMetadata } from "astro";
import type { KeyFigure } from "../components/project/KeyFigures.astro";

interface Props {
  title: string;
  year?: string;
  image?: ImageMetadata;
  externalLink?: string;
  keyFigures?: KeyFigure[];
  parentPage?: {
    title: string;
    url: string;
  };
}

const {
  title,
  year,
  image,
  externalLink,
  keyFigures,
  parentPage: explicitParentPage,
} = Astro.props;
const pageTitle = `${title} - Romuald Tisserand`;

const projects = [
  { title: "Meditect", slug: "meditect" },
  { title: "Smart-Rx", slug: "smartrx" },
  { title: "Novyspec", slug: "novyspec" },
];

const currentPath = Astro.url.pathname;
const currentIndex = projects.findIndex((p) => currentPath.includes(p.slug));
const prevProject = currentIndex > 0 ? projects[currentIndex - 1] : null;
const nextProject =
  currentIndex < projects.length - 1 ? projects[currentIndex + 1] : null;

// Auto-detect parent page for nested pages
// If we're in /pro/smartrx/logistock, detect parent as /pro/smartrx
let parentPage = explicitParentPage;
if (!parentPage) {
  const pathParts = currentPath.split("/").filter(Boolean);
  if (pathParts.length >= 3 && pathParts[0] === "pro") {
    const projectSlug = pathParts[1];
    const project = projects.find((p) => p.slug === projectSlug);
    if (project) {
      parentPage = { title: project.title, url: `/pro/${projectSlug}` };
    }
  }
}

const breadcrumbs = [
  { name: "Accueil", url: "/" },
  { name: "Projets professionnels", url: "/pro" },
  ...(parentPage ? [{ name: parentPage.title, url: parentPage.url }] : []),
  { name: title, url: currentPath },
];

const navigation = !parentPage
  ? {
      prev: prevProject
        ? { title: prevProject.title, url: `/pro/${prevProject.slug}` }
        : null,
      next: nextProject
        ? { title: nextProject.title, url: `/pro/${nextProject.slug}` }
        : null,
      prevLabel: "← Plus récente",
      nextLabel: "Plus ancienne →",
    }
  : undefined;
---

<ProjectBase
  {title}
  {pageTitle}
  {year}
  {image}
  {externalLink}
  {keyFigures}
  {breadcrumbs}
  {navigation}
  heroOverlayPosition="top"
>
  <slot />
</ProjectBase>
